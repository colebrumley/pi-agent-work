{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/colebrumley/pi-agent-work/blob/main/requirements/requirements.schema.json",
  "title": "Requirements State",
  "description": "Canonical contract for the deterministic requirements store. requirements.json conforms to this minus `decisions`; decision-log.json holds { decisions: Decision[] }. The CLI ships a dependency-free structural mirror of this schema; this file is the source of truth for external validators (ajv, check-jsonschema).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "featureName", "problemStatement", "tier",
    "goals", "nonGoals", "actors", "userJourneys",
    "functionalRequirements", "nonFunctionalRequirements", "constraints",
    "assumptions", "risks", "openQuestions", "acceptanceCriteria", "acceptanceTests",
    "testingStandards", "testExceptions", "readiness", "requirementsRevision",
    "outOfScope", "dependencies", "rollout", "observability", "security",
    "operational", "riskReviews", "handoffNotes", "meta"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "featureName": { "type": "string", "minLength": 1 },
    "problemStatement": { "type": "string" },
    "tier": { "enum": ["tiny", "small", "medium", "large", "epic"] },
    "goals": { "type": "array", "items": { "$ref": "#/$defs/namedItem" } },
    "nonGoals": { "type": "array", "items": { "$ref": "#/$defs/namedItem" } },
    "outOfScope": { "type": "array", "items": { "$ref": "#/$defs/namedItem" } },
    "actors": { "type": "array", "items": { "$ref": "#/$defs/actor" } },
    "userJourneys": { "type": "array", "items": { "$ref": "#/$defs/userJourney" } },
    "functionalRequirements": { "type": "array", "items": { "$ref": "#/$defs/requirement" } },
    "nonFunctionalRequirements": { "type": "array", "items": { "$ref": "#/$defs/requirement" } },
    "constraints": { "type": "array", "items": { "$ref": "#/$defs/constraint" } },
    "assumptions": { "type": "array", "items": { "$ref": "#/$defs/assumption" } },
    "risks": { "type": "array", "items": { "$ref": "#/$defs/risk" } },
    "openQuestions": { "type": "array", "items": { "$ref": "#/$defs/openQuestion" } },
    "acceptanceCriteria": { "type": "array", "items": { "$ref": "#/$defs/acceptanceCriterion" } },
    "acceptanceTests": { "type": "array", "items": { "$ref": "#/$defs/acceptanceTest" } },
    "testingStandards": { "$ref": "#/$defs/testingStandards" },
    "testExceptions": { "type": "array", "items": { "$ref": "#/$defs/testException" } },
    "readiness": { "$ref": "#/$defs/readiness" },
    "readinessOptOut": { "$ref": "#/$defs/readinessOptOut" },
    "requirementsRevision": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "dependencies": { "type": "array", "items": { "$ref": "#/$defs/dependency" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "rollout": { "$ref": "#/$defs/rolloutSection" },
    "observability": { "$ref": "#/$defs/optionalSection" },
    "security": { "$ref": "#/$defs/optionalSection" },
    "operational": { "$ref": "#/$defs/optionalSection" },
    "riskReviews": { "type": "array", "items": { "$ref": "#/$defs/riskReview" } },
    "handoffNotes": { "type": "array", "items": { "type": "string" } },
    "meta": {
      "type": "object",
      "required": ["createdAt", "updatedAt", "decisionSequence"],
      "properties": {
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "decisionSequence": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "namedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": { "id": { "type": "string" }, "text": { "type": "string" } }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "userJourney": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "steps"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "actor": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "priority"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "priority": { "enum": ["must", "should", "could"] },
        "rationale": { "type": "string" }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "kind": { "enum": ["technical", "business", "legal", "ux", "other"] }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "status"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "status": { "enum": ["proposed", "confirmed", "rejected", "accepted-risk"] },
        "rationale": { "type": "string" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "decision", "status", "alternatives", "source", "confidence", "relatedRequirements", "sequence", "timestamp"],
      "properties": {
        "id": { "type": "string" },
        "decision": { "type": "string" },
        "status": { "enum": ["proposed", "confirmed", "rejected", "deferred"] },
        "rationale": { "type": "string" },
        "alternatives": { "type": "array", "items": { "type": "string" } },
        "source": { "enum": ["user", "interviewer", "inferred", "existing-doc"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "relatedRequirements": { "type": "array", "items": { "type": "string" } },
        "sequence": { "type": "integer", "minimum": 1 },
        "timestamp": { "type": "string" }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "likelihood", "impact", "status"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "likelihood": { "enum": ["low", "medium", "high"] },
        "impact": { "enum": ["low", "medium", "high"] },
        "mitigation": { "type": "string" },
        "status": { "enum": ["open", "mitigated", "accepted"] }
      }
    },
    "openQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "category", "whyItMatters", "blocking", "status"],
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "category": { "type": "string" },
        "whyItMatters": { "type": "string" },
        "blocking": { "enum": ["blocking", "non-blocking", "optional"] },
        "recommendation": { "type": "string" },
        "recommendationRationale": { "type": "string" },
        "possibleDefault": { "type": "string" },
        "status": { "enum": ["open", "answered", "deferred", "accepted-risk"] },
        "linked": { "type": "string" },
        "answer": { "type": "string" },
        "answerSource": { "enum": ["user", "interviewer"] },
        "acceptedRiskAssumption": { "type": "string" },
        "stopCondition": { "type": "string" }
      }
    },
    "acceptanceCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "criterion", "testability", "priority"],
      "properties": {
        "id": { "type": "string" },
        "criterion": { "type": "string" },
        "linkedGoal": { "type": "string" },
        "linkedRequirement": { "type": "string" },
        "testability": { "enum": ["testable", "manual", "unclear"] },
        "priority": { "enum": ["must", "should", "could"] }
      }
    },
    "acceptanceTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "setup", "action", "expectedResult", "fidelityLayer", "linkedRequirement", "requiredEvidence", "categories"],
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string", "minLength": 1 },
        "setup": { "type": "string", "minLength": 1 }, "action": { "type": "string", "minLength": 1 },
        "expectedResult": { "type": "string", "minLength": 1 },
        "fidelityLayer": { "enum": ["real-end-to-end", "realistic-smoke", "integration", "unit", "static"] },
        "linkedRequirement": { "type": "string", "minLength": 1 }, "requiredEvidence": { "type": "string", "minLength": 1 },
        "categories": { "type": "array", "items": { "enum": ["happy-path", "boundaries", "malformed-input", "failure-recovery", "regression", "abuse"] }, "uniqueItems": true }
      }
    },
    "applicability": {
      "type": "object", "additionalProperties": false, "required": ["name", "applicable", "rationale"],
      "properties": { "name": { "type": "string" }, "applicable": { "type": "boolean" }, "rationale": { "type": "string" } }
    },
    "testingStandards": {
      "type": "object", "additionalProperties": false, "required": ["fidelity", "adversarial"],
      "properties": { "fidelity": { "type": "array", "items": { "$ref": "#/$defs/applicability" } }, "adversarial": { "type": "array", "items": { "$ref": "#/$defs/applicability" } } }
    },
    "testException": {
      "type": "object", "additionalProperties": false,
      "required": ["testId", "reason", "substituteVerification", "residualRisk", "explicitUserApproval", "requirementsRevision"],
      "properties": { "testId": { "type": "string" }, "reason": { "type": "string" }, "substituteVerification": { "type": "string" }, "residualRisk": { "type": "string" }, "approvedBy": { "type": "string" }, "explicitUserApproval": { "type": "boolean" }, "requirementsRevision": { "type": "string" }, "implementationCommit": { "type": "string" } }
    },
    "readiness": {
      "type": "object", "additionalProperties": false,
      "required": ["buildableEndToEnd", "rationale", "workingParameters", "assumptions", "stopConditions", "domains"],
      "properties": {
        "buildableEndToEnd": { "enum": ["yes", "no", "unanswered"] }, "rationale": { "type": "string" }, "workingParameters": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } }, "stopConditions": { "type": "array", "items": { "type": "string" } }, "assessedBy": { "type": "string" },
        "domains": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["domain", "status", "rationale"], "properties": { "domain": { "enum": ["scope", "non-scope", "behavior", "ux", "errors", "edge-cases", "data", "integrations", "compatibility", "security", "operations", "rollout", "tests", "bailout-conditions"] }, "status": { "enum": ["resolved", "not-applicable", "open"] }, "rationale": { "type": "string" } } } }
      }
    },
    "readinessOptOut": {
      "type": "object", "additionalProperties": false, "required": ["requestedByUser", "approvedBy", "requestText", "choices"],
      "properties": { "requestedByUser": { "type": "boolean" }, "approvedBy": { "type": "string" }, "requestText": { "type": "string" }, "choices": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["questionId", "answer", "rationale"], "properties": { "questionId": { "type": "string" }, "answer": { "type": "string" }, "rationale": { "type": "string" } } } } }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "status"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "enum": ["internal", "external", "team", "service", "data", "other"] },
        "status": { "enum": ["available", "pending", "at-risk", "unknown"] },
        "notes": { "type": "string" }
      }
    },
    "optionalSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicable", "notes"],
      "properties": {
        "applicable": { "type": "boolean" },
        "notApplicableReason": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rolloutSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicable", "notes", "phases"],
      "properties": {
        "applicable": { "type": "boolean" },
        "notApplicableReason": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "phases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "riskReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewedAt", "reviewer", "summary"],
      "properties": {
        "reviewedAt": { "type": "string" },
        "reviewer": { "type": "string" },
        "summary": { "type": "string" }
      }
    }
  }
}
